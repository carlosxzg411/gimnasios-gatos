# ──────────────────────────────────────────────
# Gimnasios para Gatos — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ──────────────────────────────────────────────

# ── Server ─────────────────────────────────────
PORT=8080

# ── Spring Profile ─────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── JWT (use a long random string, >=256 bits) ─
APP_JWT_SECRET=change-me-to-a-random-secret-at-least-32-characters-long

# ── MySQL ──────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_USER=gimnasios_app
MYSQL_PASSWORD=change-me-app-password
MYSQL_PORT=3307

# ── Stripe ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── SMTP (e.g. Gmail, SendGrid, Mailgun) ───────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ── Email ──────────────────────────────────────
EMAIL_FROM=no-reply@tudominio.com
EMAIL_FABRICANTE=fabricante@tudominio.com
